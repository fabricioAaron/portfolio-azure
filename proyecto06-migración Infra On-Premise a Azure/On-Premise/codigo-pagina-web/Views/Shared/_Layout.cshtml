<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AyacuchoAventura</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <style>
        html { scroll-behavior: smooth; }
        .hero-overlay { background: rgba(0, 0, 0, 0.4); }
        .card-shadow { box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); }
    </style>
</head>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

<body class="bg-gray-50 text-gray-800 font-sans">

    <!-- NAVBAR -->
    <nav class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-md border-b border-gray-200 py-3 px-6 flex justify-between items-center">
        <div class="flex items-center gap-2">
            <div class="w-10 h-10 bg-blue-700 rounded-full flex items-center justify-center text-white font-bold">M</div>
            <span class="font-bold text-xl tracking-tight uppercase">Ayacucho<span class="text-blue-700">Aventura</span></span>
        </div>
        <div class="hidden md:flex gap-6 font-medium text-gray-600">
            <a href="#experiencias" class="hover:text-blue-700 transition">Experiencias</a>
            <a href="#porque" class="hover:text-blue-700 transition">Por qué elegirnos</a>
            <a href="#seguridad" class="hover:text-blue-700 transition">Seguridad</a>
            <a href="#opiniones" class="hover:text-blue-700 transition">Opiniones</a>
            <a asp-controller="Reservas" asp-action="Index" class="hover:text-blue-700 transition font-bold">
            Panel de reservas
        </a>
        </div>
        <a href="#reservar" class="bg-orange-600 hover:bg-orange-700 text-white px-5 py-2 rounded-full font-bold transition shadow-lg">
            Reservar ahora
        </a>
    </nav>

    <!-- CONTENIDO -->
    <main role="main" class="pt-20">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="bg-gray-50 py-10 px-6 text-center text-gray-500 pb-28 md:pb-10">
        <p>© 2026 Aventurero Nohely. Turismo seguro en Ayacucho.</p>
    </footer>

</body>
</html>
